            "text": "For example:\nUse LEFT and RIGHT\nto move."
        },
        {
            "typer": "sign",
            "portrait": "sign",
            "text": "Use SPACE to jump."
        },
        {
            "typer": "sign",
            "portrait": "sign",
            "text": "And SHIFT to run!"
