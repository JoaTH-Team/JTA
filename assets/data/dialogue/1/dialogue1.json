            "text": "Hello, and welcome to\nJourney Through\nAubekhia!"
        },
        {
            "typer": "sign",
            "portrait": "sign",
            "text": "I, amongst other signs,\nare here to guide you\non your quest!"
        },
        {
            "typer": "player",
            "portrait": "player",
            "text": "What quest? I'm just\ngoing for long walk."
        },
        {
            "typer": "sign",
            "portrait": "sign",
            "text": "Wait, really? You don't\nhave something\nimportant to do?"
        },
        {
            "typer": "sign",
            "portrait": "sign",
            "text": "Like saving the world\nor something?"
        },
        {
            "typer": "player",
            "portrait": "player",
            "text": "No, not really."
        },
        {
            "typer": "player",
            "portrait": "player",
            "text": "Also, do all signs\nhere talk?"
